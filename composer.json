{
    "name": "wegil/cek-kurir-resi",
    "description": "Indonesian courier tracking API aggregator",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "RC",
    "prefer-stable": true,
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6",
        "simplehtmldom/simplehtmldom": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CekResi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CekResi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "lint": "find src/ tests/ public/ -name '*.php' -exec php -l {} \\;",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
